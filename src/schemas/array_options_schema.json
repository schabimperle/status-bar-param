{
    "$id": "array_options_schema.json",
    "definitions": {
        "plainValue": {
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "object",
                    "properties": {
                        "displayValue": {
                            "type": "string",
                            "description": "A name to display in the status bar instead of the value."
                        },
                        "value": {
                            "type": "string",
                            "description": "The value to return if selected."
                        }
                    },
                    "required": [
                        "value"
                    ]
                }
            ]
        },
        "namedValue": {
            "type": "object",
            "properties": {
                "displayValue": {
                    "type": "string",
                    "description": "The label shown in the status bar (required, since a named-value map has no single string to display)."
                },
                "value": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "minProperties": 1,
                    "description": "A map of named outputs, each retrievable via ${command:statusBarParam.get.<id>.<key>}. Lets one selection drive several outputs (e.g. a compiler pick yielding both cc and cxx)."
                }
            },
            "required": [
                "value",
                "displayValue"
            ],
            "additionalProperties": false
        },
        "valueArray": {
            "$comment": "Either a list of plain/labelled values or a list of named-output values, never a mix: a keyless ${command:…get.<id>} has no meaning for a named entry, so mixing leaves no substitution that works for every selection. anyOf (not oneOf) so an empty array — which matches both shapes — stays valid.",
            "anyOf": [
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/plainValue"
                    }
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/namedValue"
                    }
                }
            ]
        }
    },
    "if": {
        "type": "array"
    },
    "then": {
        "$ref": "#/definitions/valueArray"
    },
    "else": {
        "allOf": [
            {
                "$ref": "options_schema.json"
            },
            {
                "type": "object",
                "properties": {
                    "values": {
                        "description": "A list of parameter values to select from.",
                        "allOf": [
                            {
                                "$ref": "#/definitions/valueArray"
                            }
                        ]
                    }
                },
                "required": [
                    "values"
                ]
            }
        ]
    }
}
