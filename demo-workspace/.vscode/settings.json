{
  // Clean chrome for deterministic, distraction-free demo recordings.
  "window.title": "${rootNameShort}",
  "workbench.startupEditor": "none",
  "workbench.activityBar.location": "default",
  "workbench.statusBar.visible": true,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.tips.enabled": false,
  "workbench.colorTheme": "Dark Modern",
  "editor.fontSize": 15,
  "terminal.integrated.fontSize": 14,
  // Freeze blinking carets (editor + terminal) so a static hold collapses to ONE
  // GIF frame instead of one per blink — smaller file, and the pauses read as truly
  // still. The quick-input box's native caret is frozen via CSS in record-demo.
  "editor.cursorBlinking": "solid",
  "terminal.integrated.cursorBlinking": false,
  "window.menuBarVisibility": "hidden",
  "explorer.openEditors.visible": 0,
  "git.openRepositoryInParentFolders": "never",
  // Deterministic in-place editing in the demo: no auto-inserted quotes/brackets
  // when the driver retypes the sample task's command line.
  "editor.autoClosingBrackets": "never",
  "editor.autoClosingQuotes": "never",
  "editor.autoSurround": "never",
  "editor.suggestOnTriggerCharacters": false
}
